# ============================================================
# Ramen Bones Analytics — .env.example
# ============================================================
# Copy this file to `.env` for local dev:  cp .env.example .env
# Every variable below is annotated with its DESTINATION — the place
# a forker must paste it to run this repo in production.
#
# NEVER commit filled-in values. `.env` is in .gitignore.
# ============================================================


# --- destination: cf pages project env ---
# Set in Cloudflare Pages dashboard: Settings → Environment variables
# These are public (shipped to the browser) — use anon/publishable keys ONLY.
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...your-publishable-key...


# --- destination: supabase secrets ---
# Set via: supabase secrets set KEY=value --project-ref <ref>
# Consumed by Supabase Edge Functions at runtime (generate-insight).
# NEVER expose these to the browser.
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-api-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...
SUPABASE_URL=https://your-project.supabase.co


# --- destination: supabase vault (dashboard → database → vault) ---
# Read by the pg_cron job in migration 0017_insights_cron.sql via
# vault.decrypted_secrets. Stored encrypted at rest in the database.
# generate_insight_url    — full URL of the deployed Edge Function
#   (e.g. https://<ref>.supabase.co/functions/v1/generate-insight)
# generate_insight_bearer — the same SUPABASE_SERVICE_ROLE_KEY as above,
#   stored in Vault instead of leaking via cron.job metadata


# --- destination: github actions repo secrets + local mcp ---
# Set via: gh secret set KEY --body "value"
# Consumed by CI workflows for integration tests and migrations.
# Also consumed LOCALLY by mcp-servers/postgres.ts (the Supabase MCP server
# configured in .mcp.json). Use the Supabase DEV project connection string.
# Grab from Supabase Dashboard → Project Settings → Database → Connection string → URI.
SUPABASE_DB_URL=postgresql://postgres:password@db.<ref>.supabase.co:5432/postgres
# (Test-only secrets live in .env.test.example — kept separate by Phase 1 test infra.)


# --- destination: local dev only ---
# Used by `npm run ingest`, `npx vitest`, `supabase functions serve`.
# Same values as the prod sections above when pointing at DEV project.
# A forker can reuse the cf-pages + supabase-secrets values directly here.

# Ingest loader (Phase 2): reads CSV from Supabase Storage into public.transactions.
ORDERBIRD_CSV_BUCKET=orderbird-raw
ORDERBIRD_CSV_OBJECT=dev/ramen_bones_order_items.csv
RESTAURANT_ID=

# Referenced by tests/setup.ts session guard — prevents accidental DEV hits from test runs.
DEV_SUPABASE_URL=
