# Copy to .env (gitignored) and fill in real values.
# One file for both `npm run ingest` (DEV) and `npm test` (TEST).

# --- DEV Supabase (used by `npm run ingest`) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ORDERBIRD_CSV_BUCKET=orderbird-raw
ORDERBIRD_CSV_OBJECT=dev/ramen_bones_order_items.csv
RESTAURANT_ID=

# --- TEST Supabase (used by integration tests) ---
# Separate project from DEV. Must have migrations 0001..0009 applied.
TEST_SUPABASE_URL=
TEST_SUPABASE_ANON_KEY=
TEST_SUPABASE_SERVICE_ROLE_KEY=

# --- Optional: referenced by tests/setup.ts session guard ---
DEV_SUPABASE_URL=

# --- SvelteKit frontend (Phase 4) ---
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=
