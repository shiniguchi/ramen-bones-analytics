{
  "name": "ramen-bones-analytics",
  "version": "1.0.0",
  "description": "Atomic, copy-paste-ready starter for AI-assisted coding projects. Drop it into any new repo to get a working `.claude/` setup, doc scaffolds, and a tested workflow.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo 'svelte-kit sync skipped'",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test": "vitest run",
    "test:guards": "bash scripts/ci-guards.sh",
    "ingest": "tsx scripts/ingest/index.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "jsdom": "^29.0.2",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.103.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-scale-chromatic": "^3.1.0",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "layerchart": "^2.0.0-next.54",
    "lucide-svelte": "^1.0.1",
    "svelte": "^5.55.4",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  }
}
